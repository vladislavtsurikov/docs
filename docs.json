              "megaworld/mask-filters/slope-filter",
              "megaworld/mask-filters/noise-filter",
              "megaworld/mask-filters/textures-filter",
              "megaworld/mask-filters/concavity-filter",
              "megaworld/mask-filters/aspect-filter",
              "megaworld/mask-filters/smooth-filter",
              "megaworld/mask-filters/expand-filter",
              "megaworld/mask-filters/expand-down-filter",
              "megaworld/mask-filters/image-filter",
              "megaworld/mask-filters/mask-operations-filter"
            ]
          },
          {
            "group": "Transform Components",
            "pages": [
              "megaworld/transform-components/overview",
              "megaworld/transform-components/align",
              "megaworld/transform-components/additional-rotation",
              "megaworld/transform-components/cliffs-align",
              "megaworld/transform-components/cliffs-position",
              "megaworld/transform-components/position-offset",
              "megaworld/transform-components/rotation",
              "megaworld/transform-components/scale",
              "megaworld/transform-components/scale-clamp",
              "megaworld/transform-components/scale-fitness",
              "megaworld/transform-components/slope-position",
              "megaworld/transform-components/slope-scale",
              "megaworld/transform-components/snap-rotation",
              "megaworld/transform-components/tree-rotation"
            ]
          }
        ]
      },
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "development"
            ]
          },
          {
            "group": "Customization",
            "pages": [
              "essentials/settings",
              "essentials/navigation"
            ]
          },
          {
            "group": "Writing content",
            "pages": [
              "essentials/markdown",
              "essentials/code",
              "essentials/images",
              "essentials/reusable-snippets"
            ]
          },
          {
            "group": "AI tools",
            "pages": [
              "ai-tools/cursor",
              "ai-tools/claude-code",
              "ai-tools/windsurf"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "API documentation",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Endpoint examples",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "href": "https://mintlify.com/docs",
          "icon": "book-open-cover"
        },
        {
          "anchor": "Blog",
          "href": "https://mintlify.com/blog",
          "icon": "newspaper"
        }
      ]
